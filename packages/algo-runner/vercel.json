{
  "version": 2,
  "cleanUrls": true,
  "headers": [
    {
      "source": "/(host|runner-config)\\.js",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=0, must-revalidate"
        }
      ]
    },
    {
      "source": "/host-worker\\.js",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=0, must-revalidate"
        }
      ]
    },
    {
      "source": "/host(?:\\.html)?",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=0, must-revalidate"
        },
        {
          "key": "Content-Security-Policy",
          "value": "default-src 'self'; base-uri 'none'; object-src 'none'; frame-ancestors https://layerwallet.com https://www.layerwallet.com https://app.layerwallet.com http://localhost:4200; script-src 'self' 'unsafe-eval'; worker-src 'self'; connect-src 'self' https://api.layerwallet.com https://testnet-api.layerwallet.com https://policy.layerwallet.com; img-src 'self' data:; style-src 'self' 'unsafe-inline'; upgrade-insecure-requests"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin"
        },
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "Permissions-Policy",
          "value": "camera=(), microphone=(), geolocation=()"
        }
      ]
    }
  ],
  "rewrites": [
    {
      "source": "/",
      "destination": "/host.html"
    }
  ]
}
